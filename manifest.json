{
    "browser_specific_settings": {
        "gecko": {
            "id": "shortshider@crtlvr",
            "data_collection_permissions": {
                "required": [ "none" ],
                "optional": []
            }
        }
    },
    "manifest_version": 3,
    "name": "shortshider",
    "version": "1.1",
    "description": "blocking shorts",
    "content_scripts": [
        {
            "matches": [ "*://*.youtube.com/*" ],
            "js": [ "content.js" ],
            "run_at": "document_idle"
        }
    ]
}